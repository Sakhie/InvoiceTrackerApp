{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*",

  "AppSettings": {
    "AllowedCors": "#{AppSettings:AllowedCors}#"
  },

  "ConnectionStrings": {
    "DefaultConnection": "#{ConnectionStrings:DefaultConnection}#"
  },

  "TokenSettings": {
    "JwtSecrete": "#{TokenSettings:JwtSecrete}#",
    "Issuer": "#{TokenSettings:Issuer}#",
    "Audience": "#{TokenSettings:Audience}#",
    "ExpiryInHours": "#{TokenSettings:ExpiryInHours}#"
  }
}
